# Entra ID App Registration credentials
# See CLAUDE.md for how to create the app registration and grant permissions
TENANT_ID=your-tenant-id-here
CLIENT_ID=your-client-id-here
CLIENT_SECRET=your-client-secret-here

# Scan thresholds (optional, these are the defaults)
STALE_DAYS=90
SECRET_EXPIRY_WARNING_DAYS=30

# Optional: email address to send HTML report to (requires Mail.Send permission)
# REPORT_EMAIL=itteam@yourcompany.com

# Serve mode
SCAN_INTERVAL_HOURS=6
METRICS_PORT=5555
