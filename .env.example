# Entra ID App Registration credentials
# See README.md for how to create the app registration and grant permissions
TENANT_ID=your-tenant-id-here
CLIENT_ID=your-client-id-here
CLIENT_SECRET=your-client-secret-here

# Scan thresholds (optional, these are the defaults)
STALE_DAYS=90
SECRET_EXPIRY_WARNING_DAYS=30

# Serve mode (optional, these are the defaults)
SCAN_INTERVAL_HOURS=6
METRICS_PORT=5454

# Email reporting (optional, requires Mail.Send application permission)
# SENDER_EMAIL=alerts@yourdomain.com
# REPORT_EMAIL=itteam@yourdomain.com
